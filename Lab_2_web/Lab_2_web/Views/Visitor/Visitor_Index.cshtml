@model IEnumerable<Lab_2_web.Models.Visitor>

@{
    ViewData["Title"] = "Відвідувачі";
}

<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;600&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">

<style>
    body { font-family: 'DM Sans', sans-serif; background: #f7f5f2; }

    .page-header {
        background: linear-gradient(135deg, #1a2e1a 0%, #1e3e1e 50%, #0f4020 100%);
        color: white; padding: 2.5rem 2rem; border-radius: 16px;
        margin-bottom: 2rem; display: flex; align-items: center; justify-content: space-between;
    }
    .page-header h1 { font-family: 'Cormorant Garamond', serif; font-size: 2.2rem; font-weight: 600; margin: 0; }
    .page-header p  { margin: 0.25rem 0 0; opacity: 0.65; font-size: 0.9rem; font-weight: 300; }

    .btn-create {
        background: #e8b86d; color: #1a2e1a; border: none;
        padding: 0.65rem 1.4rem; border-radius: 8px;
        font-family: 'DM Sans', sans-serif; font-weight: 500; font-size: 0.9rem;
        text-decoration: none; transition: all 0.2s; white-space: nowrap;
    }
    .btn-create:hover { background: #d4a055; color: #1a2e1a; transform: translateY(-1px); }

    .alert-custom { border-radius: 10px; border: none; padding: 1rem 1.25rem; font-size: 0.9rem; margin-bottom: 1.5rem; }
    .alert-success-custom { background: #d4edda; color: #155724; }
    .alert-danger-custom  { background: #f8d7da; color: #721c24; }

    .visitor-card {
        background: white; border-radius: 12px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.06);
        border: 1px solid #eee; margin-bottom: 1rem;
        transition: box-shadow 0.2s, transform 0.2s;
    }
    .visitor-card:hover { box-shadow: 0 6px 24px rgba(0,0,0,0.1); transform: translateY(-2px); }

    .visitor-card-body {
        padding: 1.25rem 1.5rem;
        display: grid; grid-template-columns: 0.4fr 2fr 1.5fr 0.8fr auto;
        align-items: center; gap: 1rem;
    }
    .visitor-id { font-family: 'Cormorant Garamond', serif; font-size: 1.6rem; font-weight: 600; color: #5a9060; }
    .v-label { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.08em; color: #aaa; font-weight: 500; margin-bottom: 0.2rem; }
    .v-value { font-size: 0.95rem; color: #2d2d2d; font-weight: 500; }

    .booking-count {
        display: inline-block; padding: 0.3rem 0.8rem;
        background: #e8f5e9; color: #2e7d32;
        border-radius: 20px; font-size: 0.8rem; font-weight: 500;
    }

    .action-btns { display: flex; gap: 0.5rem; }
    .btn-action {
        width: 34px; height: 34px; border-radius: 8px; border: none;
        display: flex; align-items: center; justify-content: center;
        text-decoration: none; transition: all 0.15s; font-size: 0.85rem; cursor: pointer;
    }
    .btn-edit   { background: #fef3c7; color: #92400e; }
    .btn-delete { background: #fee2e2; color: #991b1b; }
    .btn-edit:hover   { background: #f59e0b; color: white; }
    .btn-delete:hover { background: #ef4444; color: white; }

    .empty-state {
        text-align: center; padding: 4rem 2rem; background: white;
        border-radius: 12px; box-shadow: 0 2px 12px rgba(0,0,0,0.06);
    }
    .empty-state .icon { font-size: 3rem; margin-bottom: 1rem; }
    .empty-state h4 { color: #555; font-weight: 500; }
    .empty-state p  { color: #aaa; font-size: 0.9rem; }

    @@media (max-width: 700px) {
        .visitor-card-body { grid-template-columns: 1fr auto; }
        .visitor-card-body > div:not(:first-child):not(:last-child) { display: none; }
        .page-header { flex-direction: column; gap: 1rem; text-align: center; }
    }
</style>

<div class="container py-4">

    @if (TempData["Success"] != null)
    {
        <div class="alert-custom alert-success-custom">✓ @TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert-custom alert-danger-custom">⚠ @TempData["Error"]</div>
    }

    <div class="page-header">
        <div>
            <h1>👤 Відвідувачі</h1>
            <p>Управління відвідувачами готелю</p>
        </div>
        <a asp-action="Create" class="btn-create">＋ Новий відвідувач</a>
    </div>

    @if (!Model.Any())
    {
        <div class="empty-state">
            <div class="icon">👥</div>
            <h4>Немає жодного відвідувача</h4>
            <p>Додайте першого відвідувача, натиснувши кнопку вище</p>
        </div>
    }
    else
    {
        @foreach (var visitor in Model)
        {
            <div class="visitor-card">
                <div class="visitor-card-body">
                    <div class="visitor-id">#@visitor.Id</div>

                    <div>
                        <div class="v-label">ПІБ</div>
                        <div class="v-value">@visitor.FullName</div>
                    </div>

                    <div>
                        <div class="v-label">Номер телефону</div>
                        <div class="v-value">@(visitor.PhoneNumber ?? "—")</div>
                    </div>

                    <div>
                        <div class="v-label">Бронювань</div>
                        <span class="booking-count">@visitor.Bookings.Count</span>
                    </div>

                    <div class="action-btns">
                        <a asp-action="Edit"   asp-route-id="@visitor.Id" class="btn-action btn-edit"   title="Редагувати">✏️</a>
                        <a asp-action="Delete" asp-route-id="@visitor.Id" class="btn-action btn-delete" title="Видалити">🗑</a>
                    </div>
                </div>
            </div>
        }
        <div style="text-align:right; color:#aaa; font-size:0.85rem; margin-top:0.5rem;">
            Всього: @Model.Count() відвідувачів
        </div>
    }
</div>
