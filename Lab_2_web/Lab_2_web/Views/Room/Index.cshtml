@model IEnumerable<Lab_2_web.Models.Room>

@{
    ViewData["Title"] = "Кімнати";
}

<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;600&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">

<style>
    body { font-family: 'DM Sans', sans-serif; background: #f7f5f2; }
    .page-header { background: linear-gradient(135deg, #1b3a2d 0%, #2d5a3d 50%, #1b4332 100%); color: white; padding: 2.5rem 2rem; border-radius: 16px; margin-bottom: 2rem; display: flex; align-items: center; justify-content: space-between; }
    .page-header h1 { font-family: 'Cormorant Garamond', serif; font-size: 2.2rem; font-weight: 600; margin: 0; }
    .page-header p  { margin: 0.25rem 0 0; opacity: 0.65; font-size: 0.9rem; font-weight: 300; }
    .btn-create { background: #e8b86d; color: #1a1a2e; border: none; padding: 0.65rem 1.4rem; border-radius: 8px; font-family: 'DM Sans', sans-serif; font-weight: 500; font-size: 0.9rem; text-decoration: none; transition: all 0.2s; white-space: nowrap; }
    .btn-create:hover { background: #d4a055; color: #1a1a2e; transform: translateY(-1px); }
    .alert-custom { border-radius: 10px; border: none; padding: 1rem 1.25rem; font-size: 0.9rem; margin-bottom: 1.5rem; }
    .alert-success-custom { background: #d4edda; color: #155724; }
    .alert-danger-custom  { background: #f8d7da; color: #721c24; }
    .room-card { background: white; border-radius: 12px; box-shadow: 0 2px 12px rgba(0,0,0,0.06); overflow: hidden; margin-bottom: 1rem; transition: box-shadow 0.2s, transform 0.2s; border: 1px solid #eee; }
    .room-card:hover { box-shadow: 0 6px 24px rgba(0,0,0,0.1); transform: translateY(-2px); }
    .room-card-body { padding: 1.25rem 1.5rem; display: grid; grid-template-columns: 0.4fr 1.5fr 1fr auto; align-items: center; gap: 1rem; }
    .room-number { font-family: 'Cormorant Garamond', serif; font-size: 1.6rem; font-weight: 600; color: #2d5a3d; line-height: 1; }
    .room-label { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.08em; color: #aaa; font-weight: 500; margin-bottom: 0.2rem; }
    .room-value { font-size: 0.95rem; color: #2d2d2d; }
    .action-btns { display: flex; gap: 0.5rem; }
    .btn-action { width: 34px; height: 34px; border-radius: 8px; border: none; display: flex; align-items: center; justify-content: center; text-decoration: none; transition: all 0.15s; font-size: 0.85rem; cursor: pointer; }
    .btn-view   { background: #eef2ff; color: #4f46e5; }
    .btn-edit   { background: #fef3c7; color: #92400e; }
    .btn-delete { background: #fee2e2; color: #991b1b; }
    .btn-view:hover   { background: #4f46e5; color: white; }
    .btn-edit:hover   { background: #f59e0b; color: white; }
    .btn-delete:hover { background: #ef4444; color: white; }
    .empty-state { text-align: center; padding: 4rem 2rem; background: white; border-radius: 12px; box-shadow: 0 2px 12px rgba(0,0,0,0.06); }
    .empty-state .icon { font-size: 3rem; margin-bottom: 1rem; }
    .empty-state h4 { color: #555; font-weight: 500; }
    .empty-state p  { color: #aaa; font-size: 0.9rem; }
    @@media (max-width: 600px) { .room-card-body { grid-template-columns: 1fr auto; } .room-card-body > div:not(:first-child):not(:last-child) { display: none; } .page-header { flex-direction: column; gap: 1rem; text-align: center; } }
</style>

<div class="container py-4">

    @if (TempData["Success"] != null)
    {
        <div class="alert-custom alert-success-custom">✓ @TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert-custom alert-danger-custom">⚠ @TempData["Error"]</div>
    }

    <div class="page-header">
        <div>
            <h1>🚪 Кімнати</h1>
            <p>Управління кімнатним фондом готелю</p>
        </div>
        <a asp-action="Create" class="btn-create">＋ Нова кімната</a>
    </div>

    @if (!Model.Any())
    {
        <div class="empty-state">
            <div class="icon">🚪</div>
            <h4>Немає жодної кімнати</h4>
            <p>Додайте першу кімнату, натиснувши кнопку вище</p>
        </div>
    }
    else
    {
        @foreach (var room in Model)
        {
            <div class="room-card">
                <div class="room-card-body">
                    <div class="room-number">@room.RoomNumber</div>
                    <div>
                        <div class="room-label">Номер кімнати</div>
                        <div class="room-value"><strong>@room.RoomNumber</strong></div>
                    </div>
                    <div>
                        <div class="room-label">Місткість</div>
                        <div class="room-value">👥 @room.Capacity ос.</div>
                    </div>
                    <div class="action-btns">
                        <a asp-action="Details" asp-route-id="@room.Id" class="btn-action btn-view" title="Деталі">👁</a>
                        <a asp-action="Edit"    asp-route-id="@room.Id" class="btn-action btn-edit" title="Редагувати">✏️</a>
                        <a asp-action="Delete"  asp-route-id="@room.Id" class="btn-action btn-delete" title="Видалити">🗑</a>
                    </div>
                </div>
            </div>
        }
        <div style="text-align:right; color:#aaa; font-size:0.85rem; margin-top:0.5rem;">
            Всього: @Model.Count() кімнат
        </div>
    }
</div>
