@model Lab_2_web.Models.Room

@{
    ViewData["Title"] = $"Редагування кімнати {Model.RoomNumber}";
    string roomNumber = ViewData.ModelState["roomNumber"]?.AttemptedValue ?? Model.RoomNumber ?? "";
    int capacity      = int.TryParse(ViewData.ModelState["capacity"]?.AttemptedValue, out var c) ? c : Model.Capacity;
}

<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;600&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">

<style>
    body { font-family: 'DM Sans', sans-serif; background: #f7f5f2; }
    .back-link { display: inline-flex; align-items: center; gap: 0.4rem; color: #888; text-decoration: none; font-size: 0.88rem; margin-bottom: 1.5rem; transition: color 0.15s; }
    .back-link:hover { color: #333; }
    .form-hero { background: linear-gradient(135deg, #1b3a2d 0%, #2d5a3d 50%, #1b4332 100%); color: white; border-radius: 16px; padding: 2rem 2.5rem; margin-bottom: 2rem; }
    .hero-label { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.1em; opacity: 0.55; margin-bottom: 0.3rem; }
    .form-hero h1 { font-family: 'Cormorant Garamond', serif; font-size: 2rem; font-weight: 600; margin: 0 0 0.3rem; }
    .form-hero p  { margin: 0; opacity: 0.6; font-size: 0.88rem; font-weight: 300; }
    .form-card { background: white; border-radius: 12px; box-shadow: 0 2px 12px rgba(0,0,0,0.06); border: 1px solid #eee; padding: 2rem; margin-bottom: 1.5rem; }
    .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; }
    .field-group { display: flex; flex-direction: column; }
    .field-group label { font-size: 0.78rem; font-weight: 500; color: #555; margin-bottom: 0.4rem; text-transform: uppercase; letter-spacing: 0.05em; }
    .field-group input { border: 1.5px solid #e5e5e5; border-radius: 8px; padding: 0.65rem 0.9rem; font-family: 'DM Sans', sans-serif; font-size: 0.92rem; color: #2d2d2d; background: #fafafa; transition: border-color 0.2s, box-shadow 0.2s; outline: none; }
    .field-group input:focus { border-color: #2d5a3d; box-shadow: 0 0 0 3px rgba(45,90,61,0.1); background: white; }
    .field-error { font-size: 0.78rem; margin-top: 0.3rem; color: #e53935; }
    .validation-summary { background: #fff5f5; border: 1px solid #fcc; border-radius: 8px; padding: 0.9rem 1.1rem; margin-bottom: 1.5rem; font-size: 0.88rem; color: #c0392b; }
    .validation-summary ul { margin: 0.4rem 0 0; padding-left: 1.2rem; }
    .form-actions { display: flex; gap: 1rem; }
    .btn-submit { background: #1b4332; color: white; border: none; padding: 0.8rem 2rem; border-radius: 8px; font-family: 'DM Sans', sans-serif; font-weight: 500; font-size: 0.95rem; cursor: pointer; transition: all 0.2s; }
    .btn-submit:hover { background: #2d5a3d; transform: translateY(-1px); }
    .btn-cancel { background: white; color: #666; border: 1px solid #ddd; padding: 0.8rem 1.5rem; border-radius: 8px; font-family: 'DM Sans', sans-serif; font-weight: 400; font-size: 0.9rem; text-decoration: none; transition: all 0.2s; }
    .btn-cancel:hover { background: #f5f5f5; color: #333; }
    @@media (max-width: 600px) { .form-grid { grid-template-columns: 1fr; } }
</style>

<div class="container py-4" style="max-width: 620px;">
    <a asp-action="Index" class="back-link">← Назад до списку</a>

    <div class="form-hero">
        <div class="hero-label">Редагування</div>
        <h1>🚪 Кімната @Model.RoomNumber</h1>
        <p>Зміна даних кімнати</p>
    </div>

    @if (!ViewData.ModelState.IsValid && ViewData.ModelState.Values.Any(v => v.Errors.Count > 0))
    {
        <div class="validation-summary">
            <strong>⚠ Будь ласка, виправте помилки:</strong>
            <ul>
                @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <li>@err.ErrorMessage</li>
                }
            </ul>
        </div>
    }

    <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
        @Html.AntiForgeryToken()

        <div class="form-card">
            <div class="form-grid">
                <div class="field-group">
                    <label for="roomNumber">Номер кімнати</label>
                    <input type="text" id="roomNumber" name="roomNumber" value="@roomNumber" placeholder="101" />
                    @if (ViewData.ModelState["roomNumber"]?.Errors.Count > 0)
                    {
                        <span class="field-error">@ViewData.ModelState["roomNumber"].Errors[0].ErrorMessage</span>
                    }
                </div>
                <div class="field-group">
                    <label for="capacity">Місткість (осіб)</label>
                    <input type="number" id="capacity" name="capacity" min="1" value="@capacity" />
                    @if (ViewData.ModelState["capacity"]?.Errors.Count > 0)
                    {
                        <span class="field-error">@ViewData.ModelState["capacity"].Errors[0].ErrorMessage</span>
                    }
                </div>
            </div>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn-submit">Зберегти зміни</button>
            <a asp-action="Index" class="btn-cancel">Скасувати</a>
        </div>
    </form>
</div>
