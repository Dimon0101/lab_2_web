@model Lab_2_web.Models.Booking

@{
    ViewData["Title"] = $"Бронювання #{Model.Id}";
    var nights = (Model.CheckOutDate - Model.CheckInDate).Days;
    var today = DateTime.Today;
    string statusClass, statusText;
    if (Model.CheckInDate <= today && today <= Model.CheckOutDate)
    { statusClass = "status-active"; statusText = "Активне"; }
    else if (Model.CheckInDate > today)
    { statusClass = "status-upcoming"; statusText = "Майбутнє"; }
    else
    { statusClass = "status-past"; statusText = "Минуле"; }
}

<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;600&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">

<style>
    body { font-family: 'DM Sans', sans-serif; background: #f7f5f2; }
    .back-link { display: inline-flex; align-items: center; gap: 0.4rem; color: #888; text-decoration: none; font-size: 0.88rem; margin-bottom: 1.5rem; transition: color 0.15s; }
    .back-link:hover { color: #333; }
    .details-hero { background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%); color: white; border-radius: 16px; padding: 2.5rem; margin-bottom: 1.5rem; position: relative; overflow: hidden; }
    .details-hero::after { content: '#@Model.Id'; font-family: 'Cormorant Garamond', serif; font-size: 8rem; font-weight: 600; color: rgba(255,255,255,0.05); position: absolute; right: 1.5rem; top: 50%; transform: translateY(-50%); line-height: 1; pointer-events: none; }
    .hero-label { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.1em; opacity: 0.55; margin-bottom: 0.3rem; }
    .hero-title { font-family: 'Cormorant Garamond', serif; font-size: 2rem; font-weight: 600; margin: 0 0 0.5rem; }
    .hero-sub   { opacity: 0.65; font-size: 0.9rem; font-weight: 300; }
    .status-badge { display: inline-block; padding: 0.35rem 1rem; border-radius: 20px; font-size: 0.8rem; font-weight: 500; margin-top: 0.75rem; }
    .status-active   { background: rgba(76,175,80,0.25); color: #a5d6a7; }
    .status-upcoming { background: rgba(33,150,243,0.25); color: #90caf9; }
    .status-past     { background: rgba(255,255,255,0.1); color: rgba(255,255,255,0.55); }
    .cards-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 1.5rem; }
    .info-card { background: white; border-radius: 12px; box-shadow: 0 2px 12px rgba(0,0,0,0.06); border: 1px solid #eee; padding: 1.75rem; }
    .info-card-title { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.1em; color: #c0a060; font-weight: 500; margin-bottom: 1.25rem; padding-bottom: 0.75rem; border-bottom: 1px solid #f0ede8; }
    .info-row { margin-bottom: 1rem; }
    .info-row:last-child { margin-bottom: 0; }
    .info-row-label { font-size: 0.75rem; color: #aaa; margin-bottom: 0.2rem; text-transform: uppercase; letter-spacing: 0.05em; }
    .info-row-value { font-size: 0.95rem; color: #2d2d2d; font-weight: 500; }
    .dates-card { background: white; border-radius: 12px; box-shadow: 0 2px 12px rgba(0,0,0,0.06); border: 1px solid #eee; padding: 1.75rem; margin-bottom: 1.5rem; }
    .dates-grid { display: grid; grid-template-columns: 1fr auto 1fr auto; align-items: center; gap: 1rem; }
    .date-block { text-align: center; }
    .date-block .date-label { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.08em; color: #aaa; margin-bottom: 0.4rem; }
    .date-block .date-value { font-family: 'Cormorant Garamond', serif; font-size: 1.8rem; font-weight: 600; color: #1a1a2e; line-height: 1; }
    .date-block .date-year  { font-size: 0.85rem; color: #aaa; margin-top: 0.2rem; }
    .date-arrow { color: #c0a060; font-size: 1.5rem; }
    .nights-pill { background: #f7f5f2; border: 1px solid #e8e3da; padding: 0.5rem 1.2rem; border-radius: 20px; text-align: center; }
    .nights-pill .n { font-family: 'Cormorant Garamond', serif; font-size: 1.5rem; font-weight: 600; color: #c0a060; line-height: 1; }
    .nights-pill .lbl { font-size: 0.72rem; color: #aaa; }
    .action-row { display: flex; gap: 1rem; }
    .btn-edit-page { background: #1a1a2e; color: white; border: none; padding: 0.75rem 1.75rem; border-radius: 8px; font-family: 'DM Sans', sans-serif; font-weight: 500; font-size: 0.9rem; text-decoration: none; transition: all 0.2s; }
    .btn-edit-page:hover { background: #0f3460; color: white; }
    .btn-back-page { background: white; color: #555; border: 1px solid #ddd; padding: 0.75rem 1.75rem; border-radius: 8px; font-family: 'DM Sans', sans-serif; font-weight: 400; font-size: 0.9rem; text-decoration: none; transition: all 0.2s; }
    .btn-back-page:hover { background: #f5f5f5; color: #333; }
    .btn-danger-page { background: #fff5f5; color: #c0392b; border: 1px solid #fdd; padding: 0.75rem 1.75rem; border-radius: 8px; font-family: 'DM Sans', sans-serif; font-weight: 500; font-size: 0.9rem; text-decoration: none; transition: all 0.2s; margin-left: auto; }
    .btn-danger-page:hover { background: #c0392b; color: white; border-color: #c0392b; }
    @@media (max-width: 700px) { .cards-grid { grid-template-columns: 1fr; } .dates-grid { grid-template-columns: 1fr 1fr; } .date-arrow, .nights-pill { display: none; } }
</style>

<div class="container py-4">
    <a asp-action="Index" class="back-link">← Назад до списку</a>

    <div class="details-hero">
        <div class="hero-label">Бронювання</div>
        <div class="hero-title">@Model.VisitorName</div>
        <div class="hero-sub">Кімната @Model.Room?.RoomNumber &nbsp;·&nbsp; @Model.CheckInDate.ToString("dd.MM.yyyy") — @Model.CheckOutDate.ToString("dd.MM.yyyy")</div>
        <span class="status-badge @statusClass">@statusText</span>
    </div>

    <div class="dates-card">
        <div class="info-card-title">📅 Дати проживання</div>
        <div class="dates-grid">
            <div class="date-block">
                <div class="date-label">Заїзд</div>
                <div class="date-value">@Model.CheckInDate.ToString("dd MMM")</div>
                <div class="date-year">@Model.CheckInDate.ToString("yyyy")</div>
            </div>
            <div class="date-arrow">→</div>
            <div class="date-block">
                <div class="date-label">Виїзд</div>
                <div class="date-value">@Model.CheckOutDate.ToString("dd MMM")</div>
                <div class="date-year">@Model.CheckOutDate.ToString("yyyy")</div>
            </div>
            <div class="nights-pill">
                <div class="n">@nights</div>
                <div class="lbl">ніч</div>
            </div>
        </div>
    </div>

    <div class="cards-grid">
        <div class="info-card">
            <div class="info-card-title">👤 Відвідувач</div>
            <div class="info-row">
                <div class="info-row-label">ПІБ</div>
                <div class="info-row-value">@Model.VisitorName</div>
            </div>
            <div class="info-row">
                <div class="info-row-label">Номер телефону</div>
                <div class="info-row-value">@(Model.VisitorPhone ?? "—")</div>
            </div>
        </div>
        <div class="info-card">
            <div class="info-card-title">🚪 Кімната</div>
            <div class="info-row">
                <div class="info-row-label">Номер кімнати</div>
                <div class="info-row-value">@Model.Room?.RoomNumber</div>
            </div>
            <div class="info-row">
                <div class="info-row-label">Місткість</div>
                <div class="info-row-value">@Model.Room?.Capacity особи</div>
            </div>
        </div>
    </div>

    <div class="action-row">
        <a asp-action="Index" class="btn-back-page">← Назад</a>
        <a asp-action="Edit"   asp-route-id="@Model.Id" class="btn-edit-page">✏ Редагувати</a>
        <a asp-action="Delete" asp-route-id="@Model.Id" class="btn-danger-page">🗑 Видалити</a>
    </div>
</div>
